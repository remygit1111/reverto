# Source-of-truth Caddyfile for Reverto.
#
# /etc/caddy/Caddyfile on the production VPS is a symlink to this
# file. Deploy flow:
#   1. PR + merge to main
#   2. On VPS: `make deploy` (pulls)
#   3. `sudo systemctl reload caddy` (applies)
#
# See docs/OPERATIONS.md for fuller operational context.

# Marketing site — redirects to the GitHub repository.
# Reverto is open-source; reverto.bot itself doesn't host a
# marketing site. Visitors are redirected to the repo where
# they can read the README, browse the code, or self-host.
reverto.bot {
        redir https://github.com/remygit1111/reverto permanent

        # Explicit protocol pin — Caddy v2 defaults to TLS 1.2+
        # but pinning prevents silent weakening on future upgrade
        # or operator config drift.
        tls {
                protocols tls1.2 tls1.3
        }

        log {
                output file /var/log/caddy/marketing.log {
                        roll_size 100MiB
                        roll_keep 10
                }
        }
}

# Reverto application — the FastAPI service. This is the
# operator's personal Reverto instance, exposed under
# app.reverto.bot.
app.reverto.bot {
        # Explicit protocol pin — Caddy v2 defaults to TLS 1.2+
        # but pinning prevents silent weakening on future upgrade
        # or operator config drift.
        tls {
                protocols tls1.2 tls1.3
        }

        # Security headers. Content-Security-Policy is intentionally
        # OMITTED here — the FastAPI SecurityHeadersMiddleware is
        # the canonical CSP source because it manages the inline-
        # script-hash whitelist for the auth-checked safety-net
        # script in index.html. A Caddy-level CSP would either
        # duplicate or conflict. During a rare 5xx maintenance.html
        # fallback (FastAPI down), browsers see all OTHER hardening
        # headers but no CSP — a static maintenance page with no
        # JS surface doesn't need CSP enforcement.
        #
        # HSTS stays dual-emitted (Caddy + FastAPI) — defence-in-
        # depth. RFC 6797 specifies use-strictest semantics for
        # duplicate HSTS headers, so layered defence is the correct
        # trade-off vs single-source-of-truth.
        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains"
                X-Frame-Options "DENY"
                X-Content-Type-Options "nosniff"
                Referrer-Policy "no-referrer"
                Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=()"
                # Remove the default Server header for a tiny privacy bump
                -Server
        }

        # Defence-in-depth body-size cap. The FastAPI
        # BodySizeLimitMiddleware caps every request at 1 MiB before
        # routing; this Caddy directive rejects oversized bodies one
        # layer earlier so a 200 MB upload never reaches the Python
        # process. 1MB matches the FastAPI default
        # (REVERTO_MAX_REQUEST_BODY_BYTES) — keep the two in sync.
        # Operator override: bump both Caddy AND the env-var together.
        request_body {
                max_size 1MB
        }

        reverse_proxy localhost:8080 {
                header_up X-Forwarded-Proto https
                header_up X-Forwarded-For {client_ip}
        }

        handle_errors {
                @5xx expression `{err.status_code} >= 500`
                handle @5xx {
                        root * /home/bot/reverto/web/static
                        rewrite * /maintenance.html
                        file_server
                }
        }

        log {
                output file /var/log/caddy/reverto.log {
                        roll_size 100MiB
                        roll_keep 10
                }
        }
}
