# Source-of-truth Caddyfile for Reverto.
#
# /etc/caddy/Caddyfile on the production VPS is a symlink to this
# file (set up 2026-05-03). Deploy flow:
#   1. PR + merge to main
#   2. On VPS: `make deploy` (pulls)
#   3. `sudo systemctl reload caddy` (applies)
# No manual /etc/caddy/Caddyfile copy needed — the symlink picks
# up changes automatically.
#
# See docs/runbook.md "Caddy reverse proxy" for fuller context.

# Marketing site — static HTML/CSS/JS served from disk.
# This is the public-facing reverto.bot domain. No auth, no
# Python, no DB access. Caddy serves files directly.
reverto.bot {
	root * /var/www/reverto-marketing
	file_server
	encode gzip

	# Explicit protocol pin (PT-v4-NW-010) — Caddy v2 defaults to
	# TLS 1.2+ but pinning prevents silent weakening on future
	# upgrade or operator config drift.
	tls {
		protocols tls1.2 tls1.3
	}

	# Security headers. Match the protections on app.reverto.bot
	# where applicable, with stricter CSP since the marketing
	# site has no inline scripts (verified via
	# tests/test_marketing_assets.py::test_no_inline_scripts_in_marketing_pages)
	# and no third-party CDN dependencies.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=()"
		# Remove the default Server header for a tiny privacy bump
		-Server
	}

	# 5xx fallback — same maintenance page as the app
	# serves for consistency
	handle_errors {
		@5xx expression `{err.status_code} >= 500`
		handle @5xx {
			root * /var/www/reverto-marketing
			rewrite * /maintenance.html
			file_server
		}
	}

	log {
		output file /var/log/caddy/marketing.log {
			roll_size 100MiB
			roll_keep 10
		}
	}
}

# Reverto application — the existing FastAPI service. This
# is the same backend that previously served reverto.bot;
# it now serves app.reverto.bot exclusively.
app.reverto.bot {
	# Explicit protocol pin (PT-v4-NW-010) — Caddy v2 defaults to
	# TLS 1.2+ but pinning prevents silent weakening on future
	# upgrade or operator config drift.
	tls {
		protocols tls1.2 tls1.3
	}

	# Security headers — mirror of the reverto.bot block (PT-v4-NW-002,
	# PT-v4-NW-003). Without this directive, the 5xx maintenance.html
	# fallback (served directly by Caddy) lacked CSP/HSTS/X-Frame-Options,
	# and every proxied response leaked Server: Caddy.
	#
	# Content-Security-Policy is intentionally OMITTED here — the FastAPI
	# SecurityHeadersMiddleware is the canonical CSP source for app.reverto.bot
	# because it manages the inline-script-hash whitelist for the auth-checked
	# safety-net script in index.html. A Caddy-level CSP would either
	# duplicate or conflict. During a rare 5xx maintenance.html fallback
	# (FastAPI down), browsers see all OTHER hardening headers but no CSP —
	# accepted operator-decision: a static maintenance page with no JS surface
	# doesn't need CSP enforcement.
	#
	# HSTS stays dual-emitted (Caddy + FastAPI) — defence-in-depth per
	# PT-v4-NW-006 (accepted by operator-decision 2026-05-04). RFC 6797
	# specifies use-strictest semantics for duplicate HSTS headers, so
	# layered defence is the correct trade-off vs single-source-of-truth.
	#
	# Permissions-Policy MUST stay byte-identical to the reverto.bot block
	# AND to the FastAPI SecurityHeadersMiddleware list — pinned by
	# tests/test_security_headers.py::test_permissions_policy_identical_across_caddy_and_fastapi.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=()"
		# Remove the default Server header for a tiny privacy bump
		-Server
	}

	reverse_proxy localhost:8080 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
	}

	handle_errors {
		@5xx expression `{err.status_code} >= 500`
		handle @5xx {
			root * /home/bot/reverto/web/static
			rewrite * /maintenance.html
			file_server
		}
	}

	log {
		output file /var/log/caddy/reverto.log {
			roll_size 100MiB
			roll_keep 10
		}
	}
}
