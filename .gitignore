.venv/
__pycache__/
*.pyc
*.pyo
.env
config/bots/*.yaml
config/bots/*/
logs/
keys/
credentials/
# Generated/local content under data/ stays out of git, but the
# audit-findings-tracker seed (PR feat/admin-findings-tracker) is
# shipped in-repo so the lifespan bootstrap can find it on first
# boot. Use ``data/*`` (not ``data/``) so the negation re-include
# below actually applies. Git refuses to descend into a
# fully-ignored directory.
data/*
!data/findings_seed.yaml
ml/model_store/
ml/models/
ml/results_*.json
ml/[0-9]*/
ml/candle_cache/
notebooks/.ipynb_checkpoints/
*.log
*:Zone.Identifier
# Audit rapporten: lokaal bewaard, niet in git.
# Leading slash zodat alleen de top-level audits/ directory wordt
# genegeerd. Zonder slash matcht `audits/` ook nested dirs zoals
# docs/audits/, en dat is waar v26-report + latere security-docs
# landen.
/audits/
audit_*.docx
audit_out/
backups/
parity_test_start.txt

# Local sqlite ghost (root). Guard against accidental commit
/reverto.db
