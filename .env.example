# .env.example — copy to .env and fill in values.
# .env is git-ignored; it never leaves the machine.
#
# start.sh sources this file before launching the portal so make(1)
# (which invokes /bin/sh, not bash, and therefore skips .bashrc)
# still sees every REVERTO_* / exchange credential / Telegram token
# without any shell-profile gymnastics.

# ──── Exchange credentials (required for live/paper bots) ────
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ──── Telegram notifications (optional) ────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──── Reverto portal security ────
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'
REVERTO_API_KEY=
REVERTO_SECRET_KEY=

# Set to 1 for local http://localhost development (cookies
# without the Secure flag). Leave empty / unset in production
# behind a TLS reverse proxy.
REVERTO_INSECURE_COOKIES=
