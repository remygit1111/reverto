# .env.example — copy to .env and fill in values.
# .env is git-ignored; it never leaves the machine.
#
# start.sh sources this file before launching the portal so make(1)
# (which invokes /bin/sh, not bash, and therefore skips .bashrc)
# still sees every REVERTO_* / exchange credential / Telegram token
# without any shell-profile gymnastics.

# ──── Exchange credentials (required for live/paper bots) ────
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=

# BITGET_PASSPHRASE — DEPRECATED.
#
# Passphrase is now stored per-user in the encrypted credentials
# store alongside api_key + api_secret. Save via the portal:
#   POST /api/exchanges/bitget/keys
#   { "api_key": "...", "api_secret": "...", "passphrase": "..." }
#
# This env-var is kept as a backwards-compat fallback. A future
# release will drop the env-var fallback entirely; for new
# installs, save the passphrase via the portal endpoint instead.
BITGET_PASSPHRASE=

# ──── Telegram notifications (optional) ────
# Trade alerts via the shared @RevertoAlertsBot. Each Reverto user
# connects their own chat via the /admin/telegram page; chat_ids
# are stored in the ``telegram_configs`` DB table and the global
# TELEGRAM_CHAT_ID env-var is no longer consulted at runtime
# (kept here for the legacy scripts/notify.sh fallback only).
TELEGRAM_BOT_TOKEN=
# Username of the shared bot WITHOUT the leading @ — used by the
# admin route to build the t.me/<bot>?start=<token> deeplink.
# Example: TELEGRAM_BOT_USERNAME=RevertoAlertsBot
TELEGRAM_BOT_USERNAME=
# Secret embedded in the webhook URL path. Telegram does not sign
# webhook requests, so the URL secret is the only auth gate against
# unsolicited POSTs from the internet. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
# Then run `make telegram-register-webhook` to point Telegram at
# https://app.reverto.bot/api/telegram/webhook/<this-value>.
TELEGRAM_WEBHOOK_SECRET=
# Legacy single-chat fallback consumed only by scripts/notify.sh.
# Bots no longer read this — see TELEGRAM_BOT_TOKEN comment above.
TELEGRAM_CHAT_ID=

# Optional separate bot for Claude Code status pings (`make beep`)
# so dev-workflow traffic doesn't clutter the trade-alert channel.
# scripts/notify.sh prefers these when BOTH are set; falls back to
# the TELEGRAM_* pair above when either is empty.
TELEGRAM_CLAUDE_BOT_TOKEN=
TELEGRAM_CLAUDE_CHAT_ID=

# ──── Reverto portal security ────
# Generate with: python3 -c 'import secrets; print(secrets.token_hex(32))'
REVERTO_API_KEY=
REVERTO_SECRET_KEY=

# Set to 1 for local http://localhost development (cookies
# without the Secure flag). Leave empty / unset in production
# behind a TLS reverse proxy.
REVERTO_INSECURE_COOKIES=

# Log verbosity. Valid: DEBUG, INFO (default), WARNING, ERROR.
# Flip to DEBUG for incident-debug; revert to INFO after so
# portal.log doesn't grow the rotation ceiling faster than
# usual. Leave unset in production — INFO is the right default.
REVERTO_LOG_LEVEL=
